# Shasvata root environment
# Copy to .env and fill real values before production deploy.

# Core URLs
NEXT_PUBLIC_API_URL=https://api.shasvata.com
NEXT_PUBLIC_APP_URL=https://shasvata.com/app
NEXT_PUBLIC_GOOGLE_CLIENT_ID=google_web_client_id_here
API_URL=http://shasvata-api:3001

# API
PORT=3001
NODE_ENV=development
CORS_ORIGINS=https://shasvata.com,https://www.shasvata.com,https://app.shasvata.com,http://localhost:3000,http://localhost:3002,http://localhost:3003
PORTAL_COOKIE_DOMAIN=.shasvata.com
PORTAL_APP_URL=https://shasvata.com/app
GOOGLE_WEB_CLIENT_ID=google_web_client_id_here

# Database
DATABASE_URL=postgresql://shasvata:change_me_postgres_password@postgres:5432/shasvata?schema=public
POSTGRES_DB=shasvata
POSTGRES_USER=shasvata
POSTGRES_PASSWORD=change_me_postgres_password

# Notifications
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LEAD_NOTIFICATION_FROM=Shasvata Notifications <notifications@shasvata.com>
LEAD_NOTIFICATION_TO=forms@shasvata.com
LEAD_NOTIFICATION_SUPPRESS_EMAIL_PATTERNS=@monitoring.shasvata.invalid
PORTAL_AUTH_FROM=Shasvata Portal <notifications@shasvata.com>
SMTP_HOST=mail.shasvata.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=system@shasvata.com
SMTP_PASSWORD=mailbox_password_here

# Source-side acquisition connectors
# Use at least 32 random bytes for production, for example: openssl rand -base64 32
NAYA_INTEGRATION_ENCRYPTION_KEY=replace-with-32-byte-random-secret

# Rate limiting
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX=5

# ERPNext sync
ERP_SYNC_MODE=mock
ERP_BASE_URL=https://erp.shasvata.com
ERP_API_KEY=erp_api_key_here
ERP_API_SECRET=erp_api_secret_here
ERP_COMPANY=Shasvata Private Limited

# Cashfree
CASHFREE_MODE=mock
CASHFREE_APP_ID=cf_app_id_here
CASHFREE_SECRET_KEY=cf_secret_here
CASHFREE_API_VERSION=2023-08-01
CASHFREE_WEBHOOK_SECRET=cashfree_dev_secret
CASHFREE_WEBHOOK_URL=https://api.shasvata.com/api/commerce/webhooks/cashfree

# Production deploy images
# NG_API_IMAGE=ghcr.io/rsuyash/shasvata-api:main
# NG_PUBLIC_IMAGE=ghcr.io/rsuyash/shasvata-web-public:main
# NG_APP_IMAGE=ghcr.io/rsuyash/shasvata-web-app:main
# NG_ICCAA_IMAGE=ghcr.io/rsuyash/shasvata-iccaa-web:main

# Runtime ops
# NAYA_DB_BACKUP_DIR=/home/nivi/backups/shasvata/postgres
