# General
NODE_ENV=development
APP_ENV=local
PUBLIC_BASE_URL=http://localhost:3000
INSIGHTS_BASE_URL=http://localhost:3001
INTELLIGENCE_BASE_URL=http://localhost:3002
APP_BASE_URL=http://localhost:3003
ADMIN_BASE_URL=http://localhost:3004
PLATFORM_API_BASE_URL=http://localhost:4000
INTELLIGENCE_API_BASE_URL=http://localhost:4100

# Database
POSTGRES_DB=shasvata
POSTGRES_USER=shasvata
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://shasvata:change-me@postgres:5432/shasvata

# Redis
REDIS_URL=redis://redis:6379

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004

# Email placeholder
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# Security placeholders
JWT_SECRET=replace-with-strong-secret-before-production
SESSION_SECRET=replace-with-strong-secret-before-production
API_KEY_SECRET=replace-with-strong-secret-before-production

# Deployment
GHCR_IMAGE_NAMESPACE=ghcr.io/rsuyash/shasvata
DEPLOY_TARGET_HOST=
DEPLOY_TARGET_PATH=/opt/shasvata
